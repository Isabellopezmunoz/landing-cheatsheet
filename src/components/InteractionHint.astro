---
/*
 * InteractionHint
 * Nota guía para previews que necesitan que el usuario interactúe
 * (hover, focus, scroll, click) para ver el efecto explicado.
 *
 * Uso:
 *   <InteractionHint>Pasa el ratón por encima del botón.</InteractionHint>
 */
---

<p class="interaction-hint">
  <span class="interaction-hint-arrow" aria-hidden="true">›</span>
  <slot />
</p>

<style>
  .interaction-hint {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    margin-block: var(--space-3);
    padding: var(--space-2) var(--space-3);
    border-left: 2px solid var(--accent);
    background-color: var(--bg-elev);
    max-width: var(--max-width-prose);
  }

  .interaction-hint-arrow {
    color: var(--accent);
    font-weight: var(--weight-bold);
  }
</style>
